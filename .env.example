
## API KEY for accessing Adyen Payments Processing APIs (Checkout API, Management API, etc..)
ADYEN_API_KEY=

# Public key for client-side authentication (Drop-in and Components)
# Safe to expose in browser — not used for server-side API requests
ADYEN_CLIENT_KEY=

# Merchant Account to configure and process payments
# https://docs.adyen.com/platforms/account-structure-resources/
ADYEN_MERCHANT_ACCOUNT=

# HMAC key to validate incoming webhook requests
ADYEN_HMAC_KEY=

# For Configuration API (account holders, balance accounts)
ADYEN_BALANCE_PLATFORM_API_KEY=

# For Legal Entity Management API (legal entities / KYC)
ADYEN_LEM_API_KEY=

# The platform ID itself (from the ws credential username)
ADYEN_BALANCE_PLATFORM_ID=

# The platform's liable balance account — receives the platform commission on split payments
# Created by Adyen when the Balance Platform is provisioned (not self-service)
PLATFORM_BALANCE_ACCOUNT_ID=

# https://docs.sqlalchemy.org/en/20/core/engines.html#database-urls
DATABASE_URL=sqlite:///dev.db
